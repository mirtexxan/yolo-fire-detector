{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Open Experiment Configurator",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/cloud/cloud_configurator.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Local Pipeline (YAML)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_experiment.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--config",
        "${input:pipelineConfigPathLocalLatest}"
      ]
    },
    {
      "name": "Prepare Dataset (Skip Training)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_experiment.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--config",
        "${input:pipelineConfigPathSkipTrainingLocalLatest}",
        "--skip-training"
      ]
    },
    {
      "name": "Create Cloud Bundle",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/cloud/prepare_cloud_bundle.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--output",
        "dist/yolo-fire-detector-cloud.zip",
        "--include-latest-generated-dataset",
        "${input:cloudBundleIncludeLatestGeneratedDataset}"
      ]
    },
    {
      "name": "Dataset Viewer",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/dataset/dataset_viewer.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--dataset",
        "${input:datasetViewerDataset}"
      ]
    },
    {
        "name": "Detect Webcam (Latest Model)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/detect.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--source",
        "webcam",
        "--weights",
        "${input:detectWeightsPath}",
        "--conf",
        "${input:detectConfidence}",
        "--device",
        "${input:detectDevice}"
      ]
    },
    {
      "name": "Detect Video File (Latest Model)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/detect.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--source",
        "${input:detectSourceVideoPath}",
        "--weights",
        "${input:detectWeightsPath}",
        "--conf",
        "${input:detectConfidence}",
        "--device",
        "${input:detectDevice}"
      ]
    },
    {
      "name": "Detect Stream (Latest Model)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/detect.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--source",
        "${input:detectSourceStreamUrl}",
        "--weights",
        "${input:detectWeightsPath}",
        "--conf",
        "${input:detectConfidence}",
        "--device",
        "${input:detectDevice}"
      ]
    },
    {
      "name": "Detect Image Folder (Latest Model)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/detect.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--source",
        "${input:detectSourceImageFolder}",
        "--weights",
        "${input:detectWeightsPath}",
        "--conf",
        "${input:detectConfidence}",
        "--device",
        "${input:detectDevice}"
      ]
    },
    {
      "name": "Export Model To Drive Registry",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/model_registry/drive_model_sync.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "export",
        "--auth-mode",
        "oauth",
        "--registry-name",
        "${input:driveRegistryName}",
        "--drive-parent-id",
        "${input:driveParentId}",
        "--oauth-credentials-file",
        "${input:oauthCredentialsFile}",
        "--local-persistent-root",
        "${input:registryExportPersistentRoot}",
        "--run-label",
        "${input:driveExportRunLabelOptionalAll}"
      ]
    },
    {
      "name": "Import Model From Drive Registry",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/model_registry/drive_model_sync.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "import",
        "--auth-mode",
        "oauth",
        "--registry-name",
        "${input:driveRegistryName}",
        "--drive-parent-id",
        "${input:driveParentId}",
        "--oauth-credentials-file",
        "${input:oauthCredentialsFile}",
        "--target-persistent-root",
        "${input:registryImportPersistentRoot}",
        "--run-label",
        "${input:driveImportRunLabelOptionalAll}"
      ]
    }
  ],
  "inputs": [
    {
      "id": "pipelineConfigPathLocalLatest",
      "type": "promptString",
      "description": "Path del file YAML della pipeline",
      "default": "${workspaceFolder}/configs/generated/latest.local.yaml"
    },
    {
      "id": "pipelineConfigPathSkipTrainingLocalLatest",
      "type": "promptString",
      "description": "Path del file YAML della pipeline da eseguire con --skip-training",
      "default": "${workspaceFolder}/configs/generated/latest.local.yaml"
    },
    {
      "id": "cloudBundleIncludeLatestGeneratedDataset",
      "type": "pickString",
      "description": "Create Cloud Bundle: includere l'ultimo dataset locale generato nel file zip?",
      "options": [
        "true",
        "false"
      ],
      "default": "true"
    },
    {
      "id": "detectWeightsPath",
      "type": "promptString",
      "description": "Modello per detect.py: usa 'latest' per il piu' recente oppure inserisci path .pt specifico",
      "default": "latest"
    },
    {
      "id": "detectConfidence",
      "type": "promptString",
      "description": "Soglia di confidenza per detect.py",
      "default": "0.5"
    },
    {
      "id": "detectDevice",
      "type": "promptString",
      "description": "Device per detect.py: cpu oppure indice GPU CUDA",
      "default": "cpu"
    },
    {
      "id": "detectSourceVideoPath",
      "type": "promptString",
      "description": "Path del file video da analizzare con detect.py"
    },
    {
      "id": "detectSourceStreamUrl",
      "type": "promptString",
      "description": "URL RTMP o RTSP dello stream da analizzare con detect.py"
    },
    {
      "id": "detectSourceImageFolder",
      "type": "promptString",
      "description": "Cartella di immagini da analizzare con detect.py"
    },
    {
      "id": "driveParentId",
      "type": "promptString",
      "description": "Folder ID parent su Google Drive per il registry (root = cartella principale)",
      "default": "root"
    },
    {
      "id": "oauthCredentialsFile",
      "type": "promptString",
      "description": "Path del file locale credenziali OAuth (client_secrets + token)",
      "default": "${workspaceFolder}/tools/model_registry/oauth_credentials.local.json"
    },
    {
      "id": "driveRegistryName",
      "type": "promptString",
      "description": "Sottocartella registry modelli su Drive",
      "default": "yolo-fire-detector-models"
    },
    {
      "id": "registryExportPersistentRoot",
      "type": "promptString",
      "description": "Root persistente locale usata per leggere gli export da pubblicare su Drive (all = solo cartella, all-r = ricorsivo)",
      "default": "${workspaceFolder}/artifacts/local"
    },
    {
      "id": "registryImportPersistentRoot",
      "type": "promptString",
      "description": "Root persistente locale dove salvare i modelli importati dal registry",
      "default": "${workspaceFolder}/artifacts/imported"
    },
    {
      "id": "driveExportRunLabelOptionalAll",
      "type": "promptString",
      "description": "Selettore export (vuoto = latest, all = tutti i .pt nella cartella, all-r = ricorsivo; nome/path = match esatto, altrimenti prefix startswith)",
      "default": ""
    },
    {
      "id": "datasetViewerDataset",
      "type": "promptString",
      "description": "Dataset da visualizzare: percorso assoluto, relativo, nome esatto in artifacts/local/datasets/ oppure prefisso",
      "default": ""
    },
    {
      "id": "driveImportRunLabelOptionalAll",
      "type": "promptString",
      "description": "Selettore import (vuoto = latest, all = tutte le run, all-r = alias di all; nome modello/run = match esatto, altrimenti prefix startswith)",
      "default": ""
    }
  ]
}
